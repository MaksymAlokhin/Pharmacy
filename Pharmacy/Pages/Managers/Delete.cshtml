@page
@model PharmacyApp.Pages.Managers.DeleteModel

@{
    ViewData["Title"] = "Видалити";
}

<h1>Видалити</h1>

<h3>Ви впевнені, що хочете видалити?</h3>
<div>
    <h4>@Model.Manager.FullName</h4>
    <hr />
    @if (!string.IsNullOrEmpty(@Model.Manager.Photo))
    {
        <div class="row">
            <div class="col-md-4">
                <div class="img-fluid mw-100 h-auto">
                    <img src="~/img/medicine/@Model.Manager.Photo" />
                </div>
            </div>
        </div>
    }
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Manager.FirstName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Manager.FirstName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Manager.LastName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Manager.LastName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Manager.Patronymic)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Manager.Patronymic)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Manager.Pharmacy)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Manager.Pharmacy.Id)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Manager.Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        <a asp-page="./Index">Назад до списку</a>
    </form>
</div>
