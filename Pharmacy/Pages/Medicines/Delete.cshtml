@page
@model PharmacyApp.Pages.Medicines.DeleteModel

@{
    ViewData["Title"] = "Видалити";
}

<h1>Видалити</h1>

<h3>Ви впевнені, що хочете видалити?</h3>
<div>
    <h4>@Model.Medicine.Name</h4>
    <hr />
    @if (!string.IsNullOrEmpty(@Model.Medicine.BoxArt))
    {
        <div class="row">
            <div class="col-md-4">
                <div class="img-fluid mw-100 h-auto">
                    <img src="~/img/medicine/@Model.Medicine.BoxArt" />
                </div>
            </div>
        </div>
    }
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.Price)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Medicine.Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        <a asp-page="./Index">Назад до списку</a>
    </form>
</div>
