@page
@model PharmacyApp.Pages.Medicines.DetailsModel

@{
    ViewData["Title"] = "Деталі";
}

<h1>Деталі</h1>

<div>
    <h4>@Model.Medicine.Name</h4>
    <hr />
    <div id="photo">
        @if (!string.IsNullOrEmpty(@Model.Medicine.BoxArt))
        {
            <div class="row">
                <div class="col-md-4">
                    <div class="img-fluid mw-100 h-auto">
                        <img id="upload" class="img-responsive" src="~/img/medicine/@Model.Medicine.BoxArt" />
                    </div>
                </div>
            </div>
        }
    </div>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.Price)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Medicine?.Id">Редагувати</a> |
    <a asp-page="./Index">Назад до списку</a>
</div>
