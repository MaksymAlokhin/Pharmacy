@page
@model PharmacyApp.Pages.Pharmacies.IndexModel

@{
    ViewData["Title"] = "Аптеки";
}

<h1>Аптеки</h1>

<p>
    <a asp-page="Create" title="Створити"><i class="fas fa-plus-circle fa-lg mr-1"></i></a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Pharmacy[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pharmacy[0].City)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Pharmacy) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.City)
            </td>
            <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id"><i class="fas fa-pencil-alt fa-lg"></i></a> |
                    <a asp-page="./Details" asp-route-id="@item.Id"><i class="fas fa-eye fa-lg"></i></a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id"><i class="fas fa-trash fa-lg text-danger"></i></a>
            </td>
        </tr>
}
    </tbody>
</table>
